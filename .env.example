# ElevenLabs API key — get one at https://elevenlabs.io/app/settings/api-keys
# Copy this file to .env and set your key. Do not commit .env.
ELEVENLABS_API_KEY=your_api_key_here

# Marvin (briefing when sprite = Marvin): deep / flat. Override for more robot-gloom.
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
# Eddie (briefing when sprite = Heart of Gold): upbeat American. Default Jessica; swap for Voice Library “cheerful robot” etc.
# ELEVENLABS_VOICE_ID_EDDIE=cgSgspJ2msm6clMCkdW9

# Optional: path to Planning-Sprint folder (default: ../../Planning-Sprint from server/)
# PLANNING_SPRINT_PATH=/path/to/Hitchhikers/Planning-Sprint

# Optional: base URL for clickable document/changelog links (e.g. GitHub repo: https://github.com/ORG/REPO/blob/main/Hitchhikers/Planning-Sprint/)
# PLANNING_SPRINT_BASE_URL=https://github.com/your-org/your-repo/blob/main/Hitchhikers/Planning-Sprint/

# OpenAI — clear spoken briefing (groups git docs + themes; Eddie reads this). Without it, template voice reads raw lists.
# OPENAI_API_KEY=sk-...
# OPENAI_BRIEFING_MODEL=gpt-4o-mini
# PLANNING_BRIEFING_SYNTHESIS=0   # set to disable even if key is set

# Optional: server port (default 3334)
# PORT=3334
